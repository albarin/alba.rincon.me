---
import LinkedInIcon from "@/components/icons/LinkedIn.astro";
import MailIcon from "@/components/icons/Mail.astro";
import SocialPill from "@/components/SocialPill.astro";
import Link from "@/components/Link.astro";
import CV from "./icons/CV.astro";

const personalImageAlt = "Alba Rincón";
const yearsOfExperience = new Date().getFullYear() - 2010;
---

<div class="max-w-2xl">
  <div class="mb-4 flex gap-4">
    <img
      class="size-20 rounded-full bg-indigo-200"
      src="/alba.png"
      alt={personalImageAlt}
    />
  </div>
  <h1
    class="text-4xl font-bold tracking-tight text-gray-800 dark:text-white sm:text-5xl"
  >
    Hi, I'm Alba! 👋
  </h1>
  <p
    class="mt-6 flex flex-col text-2xl text-gray-800 dark:text-gray-300 [&>strong]:font-semibold [&>strong]:text-yellow-500 dark:[&>strong]:text-yellow-200"
  >
    <span>Software engineer with {yearsOfExperience} years of experience.</span>
    <span
      >Currently working on
      <Link
        class="text-purple-700 hover:text-purple-500 dark:text-purple-500 dark:hover:text-purple-300"
        target="_blank"
        href="https://woocommerce.com"
      >
        WooCommerce
      </Link>
      at
      <Link
        class="text-blue-700 hover:text-blue-500 dark:text-blue-500 dark:hover:text-blue-300"
        target="_blank"
        isExternal
        href="https://automattic.com"
      >
        Automattic
      </Link>.
    </span>
    <span class="text-md">
      Previously at <Link
        class="hover:text-gray-500"
        target="_blank"
        isExternal
        href="https://typeform.com">Typeform</Link
      >,
      <Link
        class="hover:text-gray-500"
        target="_blank"
        isExternal
        href="https://mybuilder.com"
      >
        MyBuilder
      </Link>, and <Link
        class="hover:text-gray-500"
        target="_blank"
        isExternal
        href="https://kingeclient.com/"
      >
        KingEclient
      </Link>.
    </span>
  </p>

  <nav class="mt-8 flex flex-wrap gap-4">
    <SocialPill href="mailto:alba@rincon.me">
      <MailIcon class="size-4" />
      Contact
    </SocialPill>
    <SocialPill href="https://linkedin.com/in/albarincon">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
    <SocialPill href="/alba_rincon_cv.pdf">
      <CV class="size-4" />
      CV
    </SocialPill>
  </nav>
</div>

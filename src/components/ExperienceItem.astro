---
import Link from "./Link.astro";

interface Props {
  title: string;
  company: string;
  link: string;
  items: string[];
  date: string;
}

const { title, company, items, link, date } = Astro.props;
---

<div
  class="relative mx-12 py-2 before:absolute before:left-[-35px] before:block before:h-full before:border-l-2 before:border-black/20 before:content-[''] dark:before:border-white/15 md:gap-2 md:space-x-4"
>
  <div class="relative pb-4 md:col-span-2">
    <div class="sticky top-2">
      <span class="absolute -left-[42px] rounded-full text-5xl"> &bull; </span>

      <div class="space-y-1">
        <h3 class="text-xl font-bold">{title}</h3>
        <div>
          <h4 class="text-xl font-semibold text-gray-600 dark:text-white">
            <Link href={link}>{company}</Link>
          </h4>
          <time class="m-0 p-0 text-gray-600/80 dark:text-white/80">
            {date}
          </time>
        </div>
      </div>
    </div>
  </div>
  <div class="flex flex-col gap-2 pb-4 text-gray-600 dark:text-gray-300">
    <ul class="list-disc space-y-2">
      {items.map((item) => <li class="text-balance">{item}</li>)}
    </ul>
  </div>
</div>
